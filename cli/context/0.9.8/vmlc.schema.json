{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vmblu.dev/context/0.9.8/vmlc.schema.json",
  "title": "vmblu Linear Code Model (v0.2.0)",
  "type": "object",
  "additionalProperties": false,
  "required": ["header", "project", "analysis", "evidence", "architecture", "verification", "migration", "editor"],
  "properties": {
    "header": { "$ref": "#/$defs/Header" },
    "project": { "$ref": "#/$defs/Project" },
    "analysis": { "$ref": "#/$defs/Analysis" },
    "evidence": { "$ref": "#/$defs/Evidence" },
    "architecture": { "$ref": "#/$defs/Architecture" },
    "verification": { "$ref": "#/$defs/Verification" },
    "migration": { "$ref": "#/$defs/Migration" },
    "editor": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "Header": {
      "type": "object",
      "additionalProperties": true,
      "required": ["format", "version"],
      "properties": {
        "format": { "const": "vmblu-linear-code-model" },
        "version": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "origin": { "enum": ["design", "analysis", "hybrid"] },
        "schema": { "type": "string" },
        "generator": { "type": "object", "additionalProperties": true }
      }
    },
    "Project": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "root", "languages", "packages"],
      "properties": {
        "name": { "type": "string" },
        "root": { "type": "string" },
        "languages": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "packages": {
          "type": "array",
          "items": { "$ref": "#/$defs/Package" }
        },
        "sourceRoots": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "testRoots": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "entryPoints": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "Package": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "path", "name"],
      "properties": {
        "id": { "type": "string" },
        "path": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "Analysis": {
      "type": "object",
      "additionalProperties": true,
      "required": ["adapter", "configuration", "scannedAt", "includedPaths", "excludedPaths", "diagnostics"],
      "properties": {
        "adapter": {
          "type": "object",
          "additionalProperties": true,
          "required": ["name", "version"],
          "properties": {
            "name": { "type": "string" },
            "version": { "type": "string" }
          }
        },
        "configuration": { "type": "object", "additionalProperties": true },
        "scannedAt": { "type": "string", "format": "date-time" },
        "revision": { "type": "string" },
        "includedPaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "excludedPaths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/Diagnostic" }
        }
      }
    },
    "Evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files",
        "modules",
        "symbols",
        "imports",
        "exports",
        "calls",
        "types",
        "inherits",
        "implements",
        "routes",
        "events",
        "databaseAccess",
        "externalIntegrations",
        "environmentAccess",
        "tests",
        "diagnostics"
      ],
      "properties": {
        "files": { "type": "array", "items": { "$ref": "#/$defs/FileEvidence" } },
        "modules": { "type": "array", "items": { "$ref": "#/$defs/ModuleEvidence" } },
        "symbols": { "type": "array", "items": { "$ref": "#/$defs/SymbolEvidence" } },
        "imports": { "type": "array", "items": { "$ref": "#/$defs/ImportEvidence" } },
        "exports": { "type": "array", "items": { "$ref": "#/$defs/ExportEvidence" } },
        "calls": { "type": "array", "items": { "$ref": "#/$defs/CallEvidence" } },
        "types": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "inherits": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "implements": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "routes": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "events": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "databaseAccess": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "externalIntegrations": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "environmentAccess": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "tests": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "diagnostics": { "type": "array", "items": { "$ref": "#/$defs/Diagnostic" } }
      }
    },
    "FileEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "language", "kind", "package"],
      "properties": {
        "id": { "type": "string", "pattern": "^file:" },
        "path": { "type": "string" },
        "language": { "type": "string" },
        "kind": { "enum": ["source", "test"] },
        "package": { "type": "string" }
      }
    },
    "ModuleEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "file", "kind", "exports"],
      "properties": {
        "id": { "type": "string", "pattern": "^module:" },
        "path": { "type": "string" },
        "file": { "type": "string", "pattern": "^file:" },
        "kind": { "enum": ["unknown", "esm", "commonjs", "mixed"] },
        "exports": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "SymbolEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "qualifiedName", "kind", "visibility", "module", "source", "resolution"],
      "properties": {
        "id": { "type": "string", "pattern": "^symbol:" },
        "name": { "type": "string" },
        "qualifiedName": { "type": "string" },
        "kind": { "type": "string" },
        "visibility": { "enum": ["public", "protected", "private"] },
        "module": { "type": "string", "pattern": "^module:" },
        "signature": {
          "oneOf": [
            { "$ref": "#/$defs/Signature" },
            { "type": "null" }
          ]
        },
        "source": { "$ref": "#/$defs/Source" },
        "resolution": { "$ref": "#/$defs/Resolution" }
      }
    },
    "Signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parameters", "returns"],
      "properties": {
        "parameters": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "type"],
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" }
            }
          }
        },
        "returns": { "type": "string" }
      }
    },
    "ImportEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "fromModule", "toModule", "specifier", "kind", "symbols", "source", "resolution"],
      "properties": {
        "id": { "type": "string", "pattern": "^import:" },
        "fromModule": { "type": "string", "pattern": "^module:" },
        "toModule": { "type": "string" },
        "specifier": { "type": "string" },
        "kind": { "enum": ["static", "dynamic", "commonjs"] },
        "symbols": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "local": { "type": "string" },
              "imported": { "type": "string" }
            }
          }
        },
        "source": { "$ref": "#/$defs/Source" },
        "resolution": { "$ref": "#/$defs/Resolution" }
      }
    },
    "ExportEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "module", "kind", "specifier", "symbols", "source", "resolution"],
      "properties": {
        "id": { "type": "string", "pattern": "^export:" },
        "module": { "type": "string", "pattern": "^module:" },
        "kind": { "type": "string" },
        "specifier": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "symbols": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "source": { "$ref": "#/$defs/Source" },
        "resolution": { "$ref": "#/$defs/Resolution" }
      }
    },
    "CallEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "fromSymbol", "fromModule", "toSymbol", "toName", "toModule", "kind", "async", "source", "resolution", "confidence"],
      "properties": {
        "id": { "type": "string", "pattern": "^call:" },
        "fromSymbol": {
          "oneOf": [
            { "type": "string", "pattern": "^symbol:" },
            { "type": "null" }
          ]
        },
        "fromModule": { "type": "string", "pattern": "^module:" },
        "toSymbol": {
          "oneOf": [
            { "type": "string", "pattern": "^symbol:" },
            { "type": "null" }
          ]
        },
        "toName": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "toModule": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "kind": { "type": "string" },
        "async": { "type": "boolean" },
        "source": { "$ref": "#/$defs/Source" },
        "resolution": { "$ref": "#/$defs/Resolution" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "Diagnostic": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "code", "category", "message"],
      "properties": {
        "id": { "type": "string" },
        "code": {
          "oneOf": [
            { "type": "number" },
            { "type": "string" }
          ]
        },
        "category": { "type": "string" },
        "message": { "type": "string" },
        "source": { "$ref": "#/$defs/Source" }
      }
    },
    "Architecture": {
      "type": "object",
      "additionalProperties": true,
      "required": ["components", "interfaces", "operations", "dependencies", "layers", "resources", "policies", "exceptions", "decisions"],
      "properties": {
        "components": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "interfaces": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "operations": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "dependencies": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "layers": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "resources": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "policies": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "exceptions": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "decisions": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
      }
    },
    "Verification": {
      "type": "object",
      "additionalProperties": true,
      "required": ["rules", "results", "lastRun"],
      "properties": {
        "rules": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "results": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "lastRun": {
          "oneOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        }
      }
    },
    "Migration": {
      "type": "object",
      "additionalProperties": true,
      "required": ["targets", "candidates", "plans", "generatedArtifacts"],
      "properties": {
        "targets": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "candidates": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "plans": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "generatedArtifacts": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
      }
    },
    "Source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "range"],
      "properties": {
        "file": { "type": "string" },
        "range": { "$ref": "#/$defs/Range" }
      }
    },
    "Range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": { "$ref": "#/$defs/Point" },
        "end": { "$ref": "#/$defs/Point" }
      }
    },
    "Point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line", "column"],
      "properties": {
        "line": { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 1 }
      }
    },
    "Resolution": {
      "enum": ["exact", "static", "framework", "heuristic", "agent", "human", "unknown"]
    }
  }
}
