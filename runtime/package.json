{
  "name": "@vizualmodel/vmblu-runtime",
  "version": "0.4.0",
  "description": "vmblu runtime javascript library for running node-based apps",
  "license": "Apache-2.0",
  "author": "Vizual Model",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./rt-base": {
      "import": "./dist/rt-base/index.js",
      "require": "./dist/rt-base/index.cjs",
      "default": "./dist/rt-base/index.js"
    },
    "./rt-als": {
      "import": "./dist/rt-als/index.js",
      "require": "./dist/rt-als/index.cjs",
      "default": "./dist/rt-als/index.js"
    },
    "./rt-browser-agent": {
      "import": "./dist/rt-browser-agent/index.js",
      "require": "./dist/rt-browser-agent/index.cjs",
      "default": "./dist/rt-browser-agent/index.js"
    },
    "./rt-agent": {
      "import": "./dist/rt-nodejs-agent/index.js",
      "require": "./dist/rt-nodejs-agent/index.cjs",
      "default": "./dist/rt-nodejs-agent/index.js"
    },
    "./rt-nodejs-agent": {
      "import": "./dist/rt-nodejs-agent/index.js",
      "require": "./dist/rt-nodejs-agent/index.cjs",
      "default": "./dist/rt-nodejs-agent/index.js"
    },
    "./agent-adapters": {
      "import": "./dist/agent-adapters/index.js",
      "require": "./dist/agent-adapters/index.cjs",
      "default": "./dist/agent-adapters/index.js"
    },
    "./agent-base": {
      "import": "./dist/agent-base/index.js",
      "require": "./dist/agent-base/index.cjs",
      "default": "./dist/agent-base/index.js"
    },
    "./llm-overlay": {
      "import": "./dist/llm-overlay/index.js",
      "require": "./dist/llm-overlay/index.cjs",
      "default": "./dist/llm-overlay/index.js"
    },
    "./security": {
      "import": "./dist/security/index.js",
      "require": "./dist/security/index.cjs",
      "default": "./dist/security/index.js"
    }
  },
  "main": "./dist/rt-base/index.cjs",
  "module": "./dist/rt-base/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE.txt"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:base": "tsup rt-base/index.js --format esm,cjs --out-dir dist/rt-base --sourcemap --splitting false --keep-names",
    "build:als": "tsup rt-als/index.js --format esm,cjs --out-dir dist/rt-als --sourcemap --splitting false --keep-names",
    "build:browser-agent": "tsup rt-browser-agent/index.js --format esm,cjs --out-dir dist/rt-browser-agent --sourcemap --splitting false --keep-names",
    "build:nodejs-agent": "tsup rt-nodejs-agent/index.js --format esm,cjs --out-dir dist/rt-nodejs-agent --sourcemap --splitting false --keep-names",
    "build:agent-adapters": "tsup agent-adapters/index.js --format esm,cjs --out-dir dist/agent-adapters --sourcemap --splitting false --keep-names",
    "build:agent-base": "tsup agent-base/index.js --format esm,cjs --out-dir dist/agent-base --sourcemap --splitting false --keep-names",
    "build:llm-overlay": "tsup llm-overlay/index.js --format esm,cjs --out-dir dist/llm-overlay --sourcemap --splitting false --keep-names",
    "build:security": "tsup security/index.js --format esm,cjs --out-dir dist/security --sourcemap --splitting false --keep-names",
    "build": "npm run build:base && npm run build:als && npm run build:browser-agent && npm run build:nodejs-agent && npm run build:agent-adapters && npm run build:agent-base && npm run build:llm-overlay && npm run build:security",
    "test": "node --test ./test/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
      "eslint": "^9.36.0",
      "@eslint/js": "^9.36.0",
      "eslint-config-prettier": "^10.1.8",
      "globals": "^16.4.0",
      "prettier": "^3.6.2",
      "typescript":"^5.x",
      "tsup": "^8.5.0"
  }
}
