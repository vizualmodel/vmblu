    }
  ],
  "types": {
    "AnyPayload": {
      "kind": "primitive",
      "summary": "Opaque payload used where structure is not stabilized yet."
    },
    "Void": {
      "kind": "object",
      "summary": "No payload.",
      "fields": {}
    },
    "UiEvent": {
      "kind": "external",
      "summary": "Browser UI event object.",
      "external": {
        "library": "dom",
        "symbol": "Event"
      }
    },
    "DomElement": {
      "kind": "external",
      "summary": "DOM element reference.",
      "external": {
        "library": "dom",
        "symbol": "HTMLElement"
      }
    },
    "IFrameElement": {
      "kind": "external",
      "summary": "IFrame DOM element.",
      "external": {
        "library": "dom",
        "symbol": "HTMLIFrameElement"
      }
    },
    "ArlRef": {
      "kind": "external",
      "summary": "Path reference (ARL/LARL).",
      "external": {
        "library": "kernel",
        "symbol": "ARL"
      }
    },
    "NameChange": {
      "kind": "object",
      "summary": "Rename event payload.",
      "fields": {
        "oldName": {
          "vmbluType": "string"
        },
        "newName": {
          "vmbluType": "string"
        }
      },
      "required": [
        "oldName",
        "newName"
      ]
    },
    "RectSize": {
      "kind": "object",
      "summary": "2D size in pixels.",
      "fields": {
        "w": {
          "vmbluType": "number"
        },
        "h": {
          "vmbluType": "number"
        }
      },
      "required": [
        "w",
        "h"
      ]
    },
    "IFrameSizeChange": {
      "kind": "object",
      "summary": "Size update for hosted iframe.",
      "fields": {
        "id": {
          "vmbluType": "AnyPayload"
        },
        "rect": {
          "vmbluType": "RectSize"
        }
      },
      "required": [
        "rect"
      ]
    },
    "RunApplication": {
      "kind": "object",
      "summary": "Launch command for application runner.",
      "fields": {
        "mode": {
          "vmbluType": "string"
        },
        "js": {
          "vmbluType": "AnyPayload"
        },
        "html": {
          "vmbluType": "AnyPayload"
        }
      },
      "required": [
        "mode",
        "html"
      ]
    },
    "ContextMenuPayload": {
      "kind": "object",
      "summary": "Context menu request payload.",
      "fields": {
        "menu": {
          "vmbluType": "AnyPayload"
        },
        "event": {
          "vmbluType": "UiEvent"
        }
      },
      "required": [
        "menu",
        "event"
      ]
    },
    "FileList": {
      "kind": "array",
      "summary": "List of file references.",
      "items": {
        "vmbluType": "ArlRef"
      }
    }
  },
